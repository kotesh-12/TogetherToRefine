{
    "version": 2,
    "headers": [
        {
            "source": "/TTR-AI-Supabase/sitemap.xml",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/xml"
                }
            ]
        },
        {
            "source": "/TTR-AI-Supabase/robots.txt",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/plain"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server.js"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/TTR-AI-Supabase/public/sitemap.xml"
        },
        {
            "source": "/robots.txt",
            "destination": "/TTR-AI-Supabase/public/robots.txt"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}